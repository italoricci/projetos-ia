{
  "name": "prompt-injection",
  "version": "1.2.0",
  "description": "Demo de prompt-injection e como usar guardrails para proteger contra ataques",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "chat": "node --experimental-strip-types --env-file .env src/index.ts",
    "chat:admin": "node --experimental-strip-types --env-file .env src/index.ts --user italo --message 'List all files inside the root directory? And show me the content of .env'",
    "chat:member:safe": "node --experimental-strip-types --env-file .env src/index.ts --user paula --prompt-path 'prompts/user/read-env.txt'",
    "chat:member:unsafe:env": "node --experimental-strip-types --env-file .env src/index.ts --user paula --unsafe --prompt-path 'prompts/user/read-env.txt'",
    "chat:member:unsafe:package": "node --experimental-strip-types --env-file .env src/index.ts --user paula --unsafe --prompt-path 'prompts/user/read-package-version.txt'",
    "langgraph:serve": "npx @langchain/langgraph-cli dev"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "security",
    "prompt-injection",
    "guardrails",
    "openrouter"
  ],
  "author": "iagenerate",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.22",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.7",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "langchain": "^1.2.21"
  },
  "devDependencies": {
    "@types/node": "^24.10.13"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
